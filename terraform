#!/bin/bash

# ==========================================================
# Terraform Auto Install Script for Ubuntu
# Uses official HashiCorp repository (Recommended)
# ==========================================================

set -e

echo "Starting Terraform Installation..."

# ----------------------------------------------------------
# Step 1: Update System
# ----------------------------------------------------------
sudo apt-get update -y

# ----------------------------------------------------------
# Step 2: Install Required Packages
# ----------------------------------------------------------
sudo apt-get install -y gnupg software-properties-common curl

# ----------------------------------------------------------
# Step 3: Add HashiCorp GPG Key
# ----------------------------------------------------------
curl -fsSL https://apt.releases.hashicorp.com/gpg | sudo gpg --dearmor -o /usr/share/keyrings/hashicorp-archive-keyring.gpg

# ----------------------------------------------------------
# Step 4: Add HashiCorp Repository
# ----------------------------------------------------------
echo "deb [signed-by=/usr/share/keyrings/hashicorp-archive-keyring.gpg] https://apt.releases.hashicorp.com $(lsb_release -cs) main" | sudo tee /etc/apt/sources.list.d/hashicorp.list

# ----------------------------------------------------------
# Step 5: Update Again
# ----------------------------------------------------------
sudo apt-get update -y

# ----------------------------------------------------------
# Step 6: Install Terraform
# ----------------------------------------------------------
sudo apt-get install -y terraform

# ----------------------------------------------------------
# Step 7: Verify Installation
# ----------------------------------------------------------
echo ""
echo "Installed Terraform Version:"
terraform version

echo ""
echo "Terraform Installed Successfully!"
